{
    "swagger": "2.0",
    "info": {
        "description": "API for discovering brand locations (venues).",
        "title": "ShareBite Business API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/business/{id}": {
            "get": {
                "description": "Returns a single venue/location that belongs to a brand, including the parent brand info.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "locations"
                ],
                "summary": "Get location by ID",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Location ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.getResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.errorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.errorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.errorResponse"
                        }
                    }
                },
                "security": []
            }
        },
        "/business/{id}/locations": {
            "get": {
                "description": "Returns a paginated list of venues/locations that belong to the given brand.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "locations"
                ],
                "summary": "List brand locations",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Brand ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Page number (default: 1)",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Items per page (default: 10, max: 100)",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.listResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.errorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.errorResponse"
                        }
                    }
                },
                "security": []
            }
        },
        "/business/posts/{id}": {
            "put": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Updates a post owned by the authenticated business account.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "posts"
                ],
                "summary": "Update business post",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Post ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Updated post payload",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.updatePostRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.postResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.errorResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.errorResponse"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.errorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.errorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.errorResponse"
                        }
                    }
                }
            },
            "delete": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Deletes a post owned by the authenticated business account.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "posts"
                ],
                "summary": "Delete business post",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Post ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.errorResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.errorResponse"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.errorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/internal_business_handler_business.errorResponse"
                        }
                    }
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    },
    "security": [
        {
            "BearerAuth": []
        }
    ],
    "definitions": {
        "internal_business_handler_business.brandResponse": {
            "type": "object",
            "properties": {
                "avatar": {
                    "type": "string",
                    "example": "https://cdn.example.com/brand-avatar.png"
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "name": {
                    "type": "string",
                    "example": "ShareBite HQ"
                }
            }
        },
        "internal_business_handler_business.errorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "location with id 999 was not found"
                }
            }
        },
        "internal_business_handler_business.getResponse": {
            "type": "object",
            "properties": {
                "avatar": {
                    "type": "string",
                    "example": "https://cdn.example.com/avatar.png"
                },
                "banner": {
                    "type": "string",
                    "example": "https://cdn.example.com/banner.png"
                },
                "brand": {
                    "$ref": "#/definitions/internal_business_handler_business.brandResponse"
                },
                "description": {
                    "type": "string",
                    "example": "A cozy place in the city center."
                },
                "id": {
                    "type": "integer",
                    "example": 42
                },
                "latitude": {
                    "type": "number",
                    "example": 50.4501
                },
                "longitude": {
                    "type": "number",
                    "example": 30.5234
                },
                "name": {
                    "type": "string",
                    "example": "ShareBite Downtown"
                }
            }
        },
        "internal_business_handler_business.listItem": {
            "type": "object",
            "properties": {
                "avatar": {
                    "type": "string",
                    "example": "https://cdn.example.com/avatar.png"
                },
                "description": {
                    "type": "string",
                    "example": "A cozy place in the city center."
                },
                "id": {
                    "type": "integer",
                    "example": 42
                },
                "latitude": {
                    "type": "number",
                    "example": 50.4501
                },
                "longitude": {
                    "type": "number",
                    "example": 30.5234
                },
                "name": {
                    "type": "string",
                    "example": "ShareBite Downtown"
                }
            }
        },
        "internal_business_handler_business.listResponse": {
            "type": "object",
            "properties": {
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/internal_business_handler_business.listItem"
                    }
                }
            }
        },
        "internal_business_handler_business.postResponse": {
            "type": "object",
            "properties": {
                "content": {
                    "type": "string",
                    "example": "Updated post content"
                },
                "id": {
                    "type": "integer",
                    "example": 123
                },
                "imageUrl": {
                    "type": "string",
                    "example": "https://cdn.example.com/post.jpg"
                }
            }
        },
        "internal_business_handler_business.updatePostRequest": {
            "type": "object",
            "required": [
                "content"
            ],
            "properties": {
                "content": {
                    "type": "string",
                    "example": "Updated post content"
                }
            }
        }
    }
}