GUEST_HTTP_SERVER_HOST=0.0.0.0
GUEST_HTTP_SERVER_PORT=3800

ADMIN_HTTP_SERVER_HOST=0.0.0.0
ADMIN_HTTP_SERVER_PORT=3850

BUSINESS_HTTP_SERVER_HOST=0.0.0.0
BUSINESS_HTTP_SERVER_PORT=3900

BUSINESS_HTTP_SERVER_ALLOWED_ORIGINS=http://localhost:3000
BUSINESS_HTTP_SERVER_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS,HEAD
BUSINESS_HTTP_SERVER_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization
BUSINESS_HTTP_SERVER_EXPOSE_HEADERS=Content-Length

NOTIFICATION_HTTP_SERVER_HOST=0.0.0.0
NOTIFICATION_HTTP_SERVER_PORT=4005
NOTIFICATION_AWS_REGION=us-east-2
NOTIFICATION_SQS_QUEUE_URL=
OUTBOX_SNS_TOPIC_ARN=
# leave empty if using AWS
NOTIFICATION_SQS_ENDPOINT_URL=

AWS_SQS_IMAGE_PROCESSING_QUEUE_URL=

# replace `localhost` with `pg` if you use docker to run this application
POSTGRES_HOST=localhost

POSTGRES_PORT=5432

POSTGRES_SSL=disable

POSTGRES_USER=share
POSTGRES_PASSWORD=bite
POSTGRES_DB=share-bite
POSTGRES_MIGRATIONS_DIR=migrations

JWT_ACCESS_TOKEN_SECRET_KEY=access-token
JWT_REFRESH_TOKEN_SECRET_KEY=refresh-token

JWT_ACCESS_TOKEN_TTL=5m
JWT_REFRESH_TOKEN_TTL=4320m

APP_NAME=share-bite
APP_STAGE=dev
APP_GRACEFUL_SHUTDOWN_TIMEOUT=15s

BUSINESS_HTTP_CLIENT_BASE_URL=localhost:3900
BUSINESS_HTTP_CLIENT_SCHEME=http

BUSINESS_API_BASE_URL=http://localhost:3900
BUSINESS_API_REQUEST_TIMEOUT_SECONDS=10
BUSINESS_API_AUTH_TOKEN=my-test-token

MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp

PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@domain.com
PGADMIN_PASSWORD=admin

GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://$POSTGRES_USER:$POSTGRES_PASSWORD@$POSTGRES_HOST:$POSTGRES_PORT/$POSTGRES_DB?sslmode=$POSTGRES_SSL
GOOSE_MIGRATION_DIR=./migrations

# Resend API for email sending
# Possible values: resend, fake
EMAIL_SENDER_PROVIDER=fake
RESEND_API_KEY=YOUR_API_KEY
RESEND_FROM_EMAIL=onboarding@resend.dev
PASSWORD_RESET_TTL=30m

AUTH_MAX_SESSIONS=5

# Auth rate limits
RATE_LIMIT_AUTH_RECOVER_DURATION=10m
RATE_LIMIT_AUTH_RECOVER_REQUESTS=6

S3_PRESIGN_URL_TTL=15m

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=
GITHUB_SUCCESS_REDIRECT_URL=

# For Local (Garage): Use Endpoint, PathStyle=true, and Region=garage
# For AWS: Leave Endpoint empty, set PathStyle=false, and set Region to a real AWS region (e.g. us-east-1)
S3_ENDPOINT=http://localhost:4300
S3_REGION=garage
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=app-dev-bucket
S3_USE_PATH_STYLE=true

H3_RESOLUTION=7
H3_RECOMMEND_RADIUS=2

# For MCP: generated token to use mcp tools
BUSINESS_API_TOKEN=