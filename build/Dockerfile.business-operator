FROM golang:1.26.1-bookworm AS builder

WORKDIR /app

COPY go.sum go.mod ./
RUN go mod download

COPY . . 

RUN CGO_ENABLED=0 go build -o app ./cmd/business-operator

FROM alpine:3.20

RUN addgroup -g 1000 operatorgroup && \
    adduser -D -u 1000 -G operatorgroup operatoruser

WORKDIR /app

COPY --from=builder /app/app .

USER 1000:1000

CMD ["./app"]