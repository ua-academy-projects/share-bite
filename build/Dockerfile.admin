FROM golang:1.25.7-bookworm AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ENV CGO_ENABLED=0
ENV GOOS=linux
RUN go build -o admin-auth cmd/admin-auth-api/main.go

FROM alpine:latest
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
WORKDIR /app
COPY --from=builder /app/admin-auth .
RUN chown appuser:appgroup admin-auth
USER appuser
EXPOSE 3850
CMD ["./admin-auth"]