FROM golang:1.26.1-bookworm AS builder


ARG TARGETOS
ARG TARGETARCH

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -o app ./cmd/admin-auth-api

FROM alpine:3.20

RUN adduser -D appuser

WORKDIR /app

COPY --from=builder /app/app .

COPY --from=builder /app/internal/admin-auth/provider/email/templates \
    /app/internal/admin-auth/provider/email/templates

USER appuser

EXPOSE 3850

CMD ["./app"]
